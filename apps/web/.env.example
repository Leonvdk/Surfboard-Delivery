# Resend (contact form / booking emails)
# https://resend.com/api-keys
RESEND_API_KEY=

# Sentry — build-time only, needed for source-map upload during `next build`.
# Not required for local dev. Set in Vercel project env vars (Production + Preview).
# Create at: https://sentry.io/settings/account/api/auth-tokens/
# Scopes required: project:releases, org:read
SENTRY_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────
# /admin dashboard — database, auth, Stripe
# ─────────────────────────────────────────────────────────────

# Neon Postgres — auto-populated by Vercel when you install the
# Neon integration (Vercel dashboard → Storage → Neon → Add).
# Locally: paste the direct connection URL from your Neon project.
DATABASE_URL=

# Admin login — the /admin dashboard is protected by a single password.
# Generate the bcrypt hash with:
#   pnpm exec tsx -e 'import("bcryptjs").then(({hash}) => hash(process.argv[1], 12).then(console.log))' 'your-password'
# Then paste the resulting $2a$... hash below.
ADMIN_PASSWORD_HASH=

# Session cookie signing secret. Any 32+ character random string works.
# Generate with:  openssl rand -base64 48
SESSION_SECRET=

# Stripe — Restricted API Key (NOT a live secret key). Create at:
# https://dashboard.stripe.com/apikeys → Create restricted key
# Scopes required: `charges: read`, `customers: read`. Nothing else.
STRIPE_SECRET_KEY=
